# Gemini API Configuration
GEMINI_BASE_URL=https://api.gemini.com/v1

# Public endpoints (like getTicker) don't require authentication
# Private endpoints (like placeOrder, balances) require GEMINI_API_KEY and GEMINI_API_SECRET
GEMINI_API_KEY=your_api_key_here
GEMINI_API_SECRET=your_api_secret_here
